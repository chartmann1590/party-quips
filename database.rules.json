{
  "rules": {
    "rooms": {
      "$roomCode": {
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('hostId').val() === auth.uid)"
        },
        "players": {
          ".read": "auth != null",
          "$playerId": {
            ".write": "auth != null && ($playerId === auth.uid || root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid)"
          }
        },
        "quiplash": {
          ".read": "auth != null",
          "rounds": {
            "$round": {
              "prompts": {
                "$promptId": {
                  "text": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "playerA": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "playerB": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "answers": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
                  "submitted": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
                  "voting": {
                    ".read": "auth != null",
                    "phase": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                    "currentPromptId": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                    "votes": { "$voterId": { ".write": "auth != null && $voterId === auth.uid" } }
                  }
                }
              }
            }
          }
        },
        "fibbage": {
          ".read": "auth != null",
          "rounds": {
            "$round": {
              "prompts": {
                "$promptId": {
                  ".read": "auth != null",
                  "text": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "blank": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "category": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "playerEntries": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
                  "submitted": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
                  "choices": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                  "voting": {
                    "phase": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                    "currentPromptId": { ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid" },
                    "votes": { "$voterId": { ".write": "auth != null && $voterId === auth.uid" } }
                  }
                }
              }
            }
          }
        },
        "system": {
          ".read": "auth != null",
          ".write": "root.child('rooms').child($roomCode).child('meta/hostId').val() === auth.uid"
        }
      }
    }
  }
}