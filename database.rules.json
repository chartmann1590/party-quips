{
  "rules": {
    "rooms": {
      "$roomCode": {
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('hostId').val() === auth.uid)"
        },
        "players": {
          ".read": "auth != null",
          "$playerId": {
            ".write": "auth != null && ($playerId === auth.uid || root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid)"
          }
        },
        "quiplash": {
          ".read": "auth != null",
          "rounds": {
            "$round": {
              "prompts": {
                ".write": "root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid",
                "$promptId": {
                  "answers": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
                  "submitted": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } }
                }
              },
              "voting": {
                ".write": "root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid",
                "votes": { "$voterId": { ".write": "auth != null && $voterId === auth.uid" } }
              }
            }
          }
        },
        "fibbage": {
          ".read": "auth != null",
          "rounds": {
            "$round": {
              "prompts": {
                ".write": "root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid",
                "$promptId": {
                  "playerEntries": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
                  "submitted": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } }
                }
              },
              "voting": {
                ".write": "root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid",
                "votes": { "$voterId": { ".write": "auth != null && $voterId === auth.uid" } }
              }
            }
          }
        },
        "trivia": {
          ".read": "auth != null",
          "rounds": {
            "$round": {
              ".write": "root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid",
              "answers": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } },
              "submitted": { "$playerId": { ".write": "auth != null && $playerId === auth.uid" } }
            }
          }
        },
        "system": {
          ".read": "auth != null",
          ".write": "root.child('rooms').child($roomCode).child('meta').child('hostId').val() === auth.uid"
        }
      }
    }
  }
}
